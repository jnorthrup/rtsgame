{
  "name": "rts-game",
  "version": "1.0.0",
  "description": "Real-time strategy game with WebGL rendering",
  "main": "scripts/server.js",
  "sideEffects": false,
  "scripts": {
    "preprocess:models": "node scripts/convert-models.js",
    "dev": "npm run preprocess:models && webpack serve --mode development --open",
    "build": "npm run preprocess:models && webpack --mode production",
    "start": "npm run preprocess:models && webpack serve --mode development"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "gl-matrix": "^3.4.3",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "compression-webpack-plugin": "^11.1.0",
    "html-entities": "^2.6.0",
    "html-webpack-plugin": "^5.6.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "obj2gltf": "^3.1.4",
    "gltf-pipeline": "^4.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "copy-webpack-plugin": "^12.0.2"
  },
  "keywords": [
    "webgl",
    "rts",
    "game",
    "three.js"
  ],
  "author": "",
  "license": "MIT"
}
