{
  "name": "rtsgame-headless",
  "version": "1.0.0",
  "type": "module",
  "description": "Headless RTS Game Engine with Strategic Event Telegraph",
  "main": "headless.js",
  "scripts": {
    "headless": "node headless.js",
    "battle": "node headless.js 600",
    "quick": "node headless.js 180",
    "test-scenarios": "node scenario-tester.js",
    "test-ai": "node scenario-tester.js",
    "simulate-battles": "node battle-simulator.js",
    "analyze-cx": "node battle-simulator.js",
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "start": "npm run dev",
    "bake-off": "node bake-off.js"
  },
  "keywords": [
    "rts",
    "headless",
    "strategy",
    "simulation"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "gl-matrix": "^3.4.3",
    "immer": "^10.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/preset-react": "^7.27.1",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.2",
    "google-closure-compiler": "^20231112.0.0",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "typescript": "^5.8.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.1"
  }
}
